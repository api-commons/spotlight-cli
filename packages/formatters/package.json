  },
  "dependencies": {
    "@spotlight-rules/spotlight-core": "^1.0.0",
    "@spotlight-rules/spotlight-runtime": "^1.0.0",
    "@stoplight/path": "^1.3.2",
    "@stoplight/types": "^13.15.0",
    "@types/markdown-escape": "^1.1.3",
    "chalk": "4.1.2",
    "cliui": "7.0.4",
    "lodash": "^4.18.1",
    "markdown-escape": "^2.0.0",
    "node-sarif-builder": "^2.0.3",
    "strip-ansi": "6.0",
    "text-table": "^0.2.0",
    "tslib": "^2.8.1"
