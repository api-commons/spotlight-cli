{
  "name": "@api-commons/spotlight-ruleset-bundler",
  "version": "1.7.0",
  "homepage": "https://github.com/api-commons/spotlight-cli",
  "bugs": "https://github.com/api-commons/spotlight-cli/issues",
  "author": "Stoplight <support@stoplight.io>",
  "engines": {
    "node": "^16.20 || ^18.18 || >= 20.17"
  },
  "license": "Apache-2.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "/dist"
  ],
  "type": "commonjs",
  "exports": {
    ".": {
      "default": "./dist/index.js"
    },
    "./with-loader": {
      "node": "./dist/loader/node.js",
      "browser": "./dist/loader/browser.js",
      "default": "./dist/loader/node.js"
    },
    "./presets/*": {
      "default": "./dist/presets/*.js"
    },
    "./plugins/*": {
      "default": "./dist/plugins/*.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/api-commons/spotlight-cli.git"
  },
  "dependencies": {
    "@api-commons/spotlight-core": ">=1",
    "@api-commons/spotlight-formats": "^1.8.1",
    "@api-commons/spotlight-functions": ">=1",
    "@api-commons/spotlight-parsers": ">=1",
    "@api-commons/spotlight-ref-resolver": "^1.0.4",
    "@api-commons/spotlight-ruleset-migrator": "^1.9.6",
    "@api-commons/spotlight-rulesets": ">=1",
    "@api-commons/spotlight-runtime": "^1.1.2",
    "@rollup/plugin-commonjs": "~22.0.2",
    "@stoplight/path": "1.3.2",
    "@stoplight/types": "^13.6.0",
    "@types/node": "*",
    "pony-cause": "1.1.1",
    "rollup": "~2.80.0",
    "tslib": "^2.8.1",
    "validate-npm-package-name": "3.0.0"
  },
  "devDependencies": {
    "@types/validate-npm-package-name": "^3.0.3",
    "fetch-mock": "^12.6.0",
    "memfs": "^3.5.3",
    "prettier": "^2.4.1"
  },
  "publishConfig": {
    "access": "public"
  }
}
